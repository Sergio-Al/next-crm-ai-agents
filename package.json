{
  "name": "crm-agent-platform",
  "private": true,
  "scripts": {
    "db:generate": "pnpm --filter @crm-agent/shared db:generate",
    "db:migrate": "pnpm --filter @crm-agent/shared db:migrate",
    "db:push": "pnpm --filter @crm-agent/shared db:push",
    "db:studio": "pnpm --filter @crm-agent/shared db:studio",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "seed": "tsx scripts/seed.ts"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "devDependencies": {
    "tsx": "^4.7.0",
    "typescript": "^5.5.0"
  }
}
