# ═══════════════════════════════════════════════════
# Database
# ═══════════════════════════════════════════════════

# Direct PostgreSQL (for migrations / Drizzle Studio)
POSTGRES_URL=postgresql://platform:platform@localhost:5432/platform

# Via PgBouncer (for application connections)
DATABASE_URL=postgresql://platform:platform@localhost:6432/platform

# ═══════════════════════════════════════════════════
# Redis
# ═══════════════════════════════════════════════════

REDIS_URL=redis://localhost:6379

# ═══════════════════════════════════════════════════
# LLM API Keys
# ═══════════════════════════════════════════════════

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-...
GOOGLE_API_KEY=sk-...

# ═══════════════════════════════════════════════════
# Auth
# ═══════════════════════════════════════════════════

AUTH_SECRET=change-me-to-a-random-secret

# ═══════════════════════════════════════════════════
# Gateway
# ═══════════════════════════════════════════════════

GATEWAY_PORT=18789
